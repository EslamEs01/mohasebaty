{
  "name": "mohasebaty-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "منصة محاسبتي — واجهة المستخدم لمنصة محاسبة عربية RTL",
  "scripts": {
    "setup:fonts": "node scripts/setup-fonts.js",
    "build:css": "tailwindcss -i ./assets/css/input.css -o ./assets/css/output.css --minify",
    "watch:css": "tailwindcss -i ./assets/css/input.css -o ./assets/css/output.css --watch",
    "build": "npm run setup:fonts && npm run build:css",
    "serve": "python3 -m http.server 8000"
  },
  "devDependencies": {
    "@fontsource/ibm-plex-mono": "^5.0.0",
    "@fontsource/ibm-plex-sans-arabic": "^5.0.0",
    "tailwindcss": "^3.4.0"
  }
}
